{
  "name": "lifehub-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:tauri": "vite --mode tauri",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:tauri": "run-p type-check \"build-only:tauri\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "build-only:tauri": "vite build --mode tauri",
    "type-check": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write --experimental-cli src/",
    "api:gen": "openapi-typescript http://localhost:5091/openapi/v1.json -o src/api/schema.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.2",
    "@primevue/forms": "^4.5.4",
    "@vueuse/gesture": "^2.0.0",
    "axios": "^1.13.2",
    "dompurify": "^3.2.3",
    "marked": "^15.0.7",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primelocale": "^2.2.3",
    "primevue": "^4.5.4",
    "rrule": "^2.8.1",
    "vue": "^3.5.26",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.10.1",
    "prettier": "3.6.2",
    "typescript": "~5.9.0",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.5"
  }
}
